/** pages/index/index.wxss **/

page {
  padding: 32rpx 24rpx;
  background-color: #f5f7fb;
  box-sizing: border-box;
}

.page {
  display: flex;
  justify-content: center;
}

.app-card {
  width: 100%;
  max-width: 700rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 35, 71, 0.08);
  box-sizing: border-box;
}

.app-header {
  margin-bottom: 32rpx;
}

.app-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}

.app-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
}

.login-section {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #2f80ed;
  color: #ffffff;
}

.login-hint {
  font-size: 22rpx;
  color: #777;
  line-height: 1.6;
}

.content {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f9fd;
}

.label {
  font-size: 26rpx;
  color: #555;
}

.value {
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
  text-align: right;
}

.value.ok {
  color: #27ae60;
}

.value.openid {
  font-size: 22rpx;
  color: #555;
}

.value.date-value {
  font-size: 24rpx;
  color: #2f80ed;
}
.tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #888;
  line-height: 1.6;
}

.settings-grid {
  margin-top: 12rpx;
  padding: 14rpx 10rpx;
  border-radius: 18rpx;
  background: #f8f9fd;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.settings-row {
  display: flex;
  gap: 10rpx;
}

.settings-item {
  flex: 1;
}

.settings-item.full {
  flex: 1;
}

.settings-label {
  font-size: 22rpx;
  color: #777;
  margin-bottom: 4rpx;
}

.settings-input {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  border: 1px solid #dde3f3;
  background: #ffffff;
  font-size: 24rpx;
}

.settings-picker {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  border: 1px solid #dde3f3;
  background: #ffffff;
  font-size: 24rpx;
}

.settings-actions {
  margin-top: 6rpx;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.save-btn {
  border-color: #2f80ed;
}

.daytype-segment {
  margin-top: 4rpx;
  display: flex;
  border-radius: 999rpx;
  border: 1px solid #dde3f3;
  overflow: hidden;
}

.daytype-btn {
  flex: 1;
  padding: 10rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #777;
  background: #ffffff;
}

.daytype-btn.active {
  background: #e3f0ff;
  color: #2f80ed;
  font-weight: 600;
}

.summary-list {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.summary-row {
  padding: 10rpx 4rpx;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.summary-name {
  font-size: 24rpx;
  font-weight: 500;
}

.summary-values {
  font-size: 22rpx;
  color: #777;
}

.summary-bar-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: #eceff5;
  overflow: hidden;
}

.summary-bar {
  height: 100%;
  border-radius: 999rpx;
}

.summary-bar.over {
  background-color: #eb5757 !important;
}

.section {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1px dashed #e0e4ee;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #444;
}

.date-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f1f4ff;
  font-size: 24rpx;
  color: #2f80ed;
}

.meal-card {
  margin-bottom: 20rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: #f8f9fd;
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.meal-title {
  font-size: 26rpx;
  font-weight: 600;
}

.meal-sub {
  font-size: 22rpx;
  color: #777;
}

.meal-form {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.picker-display {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1px solid #dde3f3;
  font-size: 24rpx;
  color: #333;
}

.grams-input {
  margin-top: 4rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  border: 1px solid #dde3f3;
  background: #ffffff;
  font-size: 24rpx;
}

.btn-outline {
  margin-top: 4rpx;
  background: #ffffff;
  color: #2f80ed;
  border: 1px solid #d1e2ff;
}

.btn-danger {
  background: #ffffff;
  color: #eb5757;
  border-radius: 999rpx;
  border: 1px solid rgba(235, 87, 87, 0.35);
  padding: 0 16rpx;
}

.entries {
  border-top: 1px dashed #e0e4ee;
  padding-top: 10rpx;
}

.entry-empty {
  font-size: 22rpx;
  color: #999;
}

.entry-row {
  margin-top: 8rpx;
  padding: 10rpx 12rpx;
  border-radius: 14rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.entry-main {
  max-width: 70%;
}

.entry-name {
  font-size: 24rpx;
  color: #333;
}

.entry-name.deleted {
  color: #999;
}

.entry-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #777;
}

.food-form {
  margin-top: 8rpx;
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: #f8f9fd;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.food-input {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  border: 1px solid #dde3f3;
  background: #ffffff;
  font-size: 24rpx;
}

.food-macros-row {
  display: flex;
  gap: 8rpx;
}

.food-macro-input {
  flex: 1;
  padding: 12rpx 14rpx;
  border-radius: 999rpx;
  border: 1px solid #dde3f3;
  background: #ffffff;
  font-size: 22rpx;
}

.foods-list {
  margin-top: 12rpx;
  max-height: 380rpx;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.food-row {
  padding: 12rpx 10rpx;
  border-radius: 14rpx;
  background: #ffffff;
}

.food-main {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.food-name {
  font-size: 24rpx;
  color: #333;
}

.food-sub {
  font-size: 22rpx;
  color: #777;
}

.food-tag {
  margin-left: 10rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  border: 1px solid #dde2f0;
  font-size: 20rpx;
  color: #777;
}

.food-tag.user {
  border-color: rgba(47, 128, 237, 0.4);
  color: #2f80ed;
  background: #ecf4ff;
}

